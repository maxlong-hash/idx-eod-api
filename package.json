{
  "name": "mcp-eod",
  "version": "1.0.0",
  "description": "MCP server for querying IDX end-of-day (EOD) stock data from a local dataset file.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js --transport=http",
    "start:http": "node src/index.js --transport=http",
    "start:stdio": "node src/index.js --transport=stdio",
    "eod:update": "node scripts/apply-eod-update.js"
  },
  "keywords": [
    "mcp",
    "eod",
    "stocks",
    "idx",
    "chatgpt"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  }
}
